# STT (Speech-to-Text) Configuration
#
# Place this file as stt.yaml in your user folder:
#   /sync/{username}/stt.yaml
#
# This enables audio file processing for your account.
# Audio files dropped in the incoming folder will be:
#   1. Classified by MrDocument based on filename
#   2. Transcribed by the STT service (ElevenLabs) with context-aware keyterms
#   3. Corrected and formatted by MrDocument
#   4. Saved as PDF and text files
#
# Transcription keyterms are automatically determined from:
#   - Context-level transcription_keyterms in your context YAML files
#   - Candidate-level transcription_keyterms for matched field values
#
# Supported audio formats:
#   Direct: .flac, .wav, .mp3, .ogg, .webm
#   Auto-converted: .mp4, .m4a, .mkv, .avi, .mov

# Language code for transcription (ISO 639-1 with optional region)
# Examples: de-DE, en-US, fr-FR, es-ES
language: de-DE

# ElevenLabs transcription model
# Options: scribe_v1, scribe_v1_experimental, scribe_v2 (recommended)
elevenlabs_model: scribe_v2

# Enable speaker diarization (identify who said what)
enable_diarization: true

# Expected number of speakers (used when diarization is enabled)
diarization_speaker_count: 2
