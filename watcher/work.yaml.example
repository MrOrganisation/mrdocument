# work.yaml - Work Context Configuration
#
# This file defines the "work" context for document processing.
# Place in your user folder: /sync/alice/work.yaml
#
# ==============================================================================
# Required Fields
# ==============================================================================

name: work
description: Work-related business documents including invoices, contracts, and correspondence

# ==============================================================================
# Filename Pattern (Required)
# ==============================================================================
# Pattern for generating filenames. Use {field_name} placeholders.
# The {date} placeholder is always available.
# Other placeholders must match fields defined below.
# The special {source_filename} placeholder resolves to the original filename
# (without extension).
#
# Simple pattern (single string):
#   filename: "{type}-{date}-{sender}-{topic}"
#
# Conditional patterns (list of rules):
# The first rule whose 'match' regex matches the incoming filename is used.
# Exactly one entry without 'match' is required as the default fallback.
#
#   filename:
#     - match: "^scan_.*"
#       pattern: "{type}-{date}-{source_filename}"
#     - match: "^IMG_.*"
#       pattern: "{date}-{source_filename}"
#     - pattern: "{type}-{date}-{sender}-{topic}"  # default (no match)

filename: "{type}-{date}-{sender}-{topic}"

# ==============================================================================
# Fields Configuration (Required)
# ==============================================================================
#
# All fields must be defined inside the 'fields' object.
# The 'date' field is always available automatically - do not define it here.
#
# Each field MUST have:
#   - instructions: Semantic description of this field (REQUIRED)
#
# Each field MAY have:
#   - candidates: List of allowed values
#     - Not defined or null: No concept of candidates for this field
#     - []: Empty list, new candidates will be tracked when AI invents them
#     - [...]: List of candidates to choose from
#       - Simple strings: ["Invoice", "Contract"]
#       - Objects with name/short/clues/allow_new_clues:
#         - name: Display name shown to AI and used in metadata (required)
#         - short: Short form used in filenames (optional, uses name if missing)
#         - clues: List of clues to help AI understand when to use this value (optional)
#         - allow_new_clues: If true, AI can suggest new clues for this candidate (default: false)
#
#   - blacklist: Values the AI should never use (always strings)
#
#   - allow_new_candidates: Whether AI can invent new values (default: true)
#     - true: AI can create new values if none match
#     - false: AI MUST choose from candidates (enforced via JSON schema enum)
#     - If candidates is [], allow_new_candidates must be true
#
# When allow_new_candidates is true and AI creates a new value, it's automatically
# added to the candidates list in this file.

fields:
  # ==============================================================================
  # Type Field
  # ==============================================================================
  type:
    instructions: |
      Choose the document type based on its business purpose.
      For financial documents, distinguish between incoming (bills) and outgoing (invoices).
    candidates:
      - name: "Invoice"
        short: "Invoice"
        clues:
          - "Outgoing payment request sent to a client"
          - "Contains 'Invoice' or 'Rechnung' header"
        allow_new_clues: true
      - name: "Bill"
        short: "Bill"
        clues:
          - "Incoming payment request from a vendor or supplier"
          - "Payment due to external party"
        allow_new_clues: true
      - name: "Contract"
        short: "Contract"
        clues:
          - "Legal agreement between parties"
          - "Contains signature lines"
        allow_new_clues: true
      - name: "Receipt"
        short: "Receipt"
        clues:
          - "Confirmation of payment received or made"
        allow_new_clues: false
      - name: "Quote"
        short: "Quote"
        clues:
          - "Price estimate or proposal for future work"
        allow_new_clues: false
    blacklist:
      - "Unknown"
      - "Other"
      - "Document"
    allow_new_candidates: true

  # ==============================================================================
  # Sender Field
  # ==============================================================================
  sender:
    instructions: |
      Identify the sender, author, or issuing organization of the document.
    candidates:
      - "Acme Corp"
      - "Globex Industries"
      - "Initech"
    allow_new_candidates: true

  # ==============================================================================
  # Topic Field
  # ==============================================================================
  topic:
    instructions: |
      Use the project name or client name as the topic.
      All documents related to the same project should share the same topic.
    candidates:
      - "Project Alpha"
      - "Project Beta"
      - "General Operations"
    blacklist:
      - "Miscellaneous"
      - "Other"
    allow_new_candidates: true

  # ==============================================================================
  # Subject Field (no candidates)
  # ==============================================================================
  subject:
    instructions: |
      Provide a brief description of the specific document content.
      Example: "Q4 2024 Services" or "License Agreement Renewal"
    # No candidates - free-form field

  # ==============================================================================
  # Keywords Field (no candidates)
  # ==============================================================================
  keywords:
    instructions: |
      Include relevant business terms, amounts, and reference numbers.
      Do not repeat the type, sender, or topic in keywords.
    # No candidates - free-form field
