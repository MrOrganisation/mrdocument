{
  "mcpServers": {
    "mrdocument": {
      "command": "poetry",
      "args": [
        "run", "mrdocument-proxy",
        "--url", "${MRDOCUMENT_URL:-https://mcp.mrdocument.parmenides.net}",
        "--user", "${MRDOCUMENT_USER}",
        "--password-file", "${MRDOCUMENT_PASSWORD_FILE}",
        "--verbose"
      ]
    }
  }
}
