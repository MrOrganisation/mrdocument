FROM node:22-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 curl && \
    rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

# Run as non-root user (node user comes with the base image)
USER node

# Minimal config so the CLI doesn't complain about missing ~/.claude.json
RUN echo '{"hasCompletedOnboarding":true}' > /home/node/.claude.json

COPY claude-code-adapter/server.py /app/server.py

WORKDIR /app
EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD curl -sf http://localhost:8080/health || exit 1

CMD ["python3", "server.py"]
